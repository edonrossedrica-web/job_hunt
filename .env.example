# SMTP settings (required to email feedback/support)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Where to receive messages (defaults to SMTP_USER if omitted)
FEEDBACK_TO=your-email@example.com

# Optional
FEEDBACK_FROM=your-email@example.com
FEEDBACK_SUBJECT_PREFIX=HireUp

# OAuth (optional; enables real Google/LinkedIn/Facebook sign-in buttons)
GOOGLE_CLIENT_ID=your-google-client-id
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
FACEBOOK_GRAPH_VERSION=v22.0

# Transactional email via Brevo API (recommended on Render)
BREVO_API_KEY=

# Persistent storage via Supabase (recommended on Render free)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional overrides
SUPABASE_DB_TABLE=app_state
SUPABASE_DB_ROW_ID=smart_hunt_db_v1

# Public app URL on your host, for example:
# PUBLIC_ORIGIN=https://your-app.up.railway.app
PUBLIC_ORIGIN=

# Persistent data directory on the host, for example:
# SMART_HUNT_DATA_DIR=/data
# Leave SMART_HUNT_DATA_DIR empty when using Supabase on Render free.
SMART_HUNT_DATA_DIR=
